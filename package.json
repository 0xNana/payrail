{
  "name": "payrail-app",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "build": "pnpm --filter @payrail/web build",
    "payrail:chain": "pnpm --filter @payrail/contracts run node",
    "payrail:deploy:local": "pnpm --filter @payrail/contracts run deploy:localhost",
    "payrail:export:sdk": "pnpm --filter @payrail/contracts run export:sdk:localhost",
    "payrail:deploy:arbitrum-sepolia": "pnpm --filter @payrail/contracts run deploy:arbitrumSepolia",
    "payrail:export:sdk:arbitrum-sepolia": "pnpm --filter @payrail/contracts run export:sdk:arbitrumSepolia",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint \"apps/**/*.{ts,tsx,js,jsx}\" \"packages/**/*.{ts,tsx,js,jsx}\" --max-warnings 0 --no-error-on-unmatched-pattern",
    "payrail:test:contracts": "pnpm --filter @payrail/contracts test",
    "payrail:web:build": "pnpm --filter @payrail/web build",
    "payrail:web": "pnpm --filter @payrail/web dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.4.0",
    "@fhenixprotocol/cofhe-contracts": "^0.1.3"
  },
  "pnpm": {
    "overrides": {
      "axios@<0.30.3": "0.30.3",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "h3@<1.15.9": "1.15.9",
      "handlebars@<4.7.9": "4.7.9",
      "hono@<4.12.7": "4.12.7",
      "immutable@<4.3.8": "4.3.8",
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "serialize-javascript@<7.0.5": "7.0.5",
      "flatted@<3.4.2": "3.4.2",
      "undici@<6.24.0": "6.24.0",
      "socket.io-parser@<4.2.6": "4.2.6",
      "ajv@<6.14.0": "6.14.0",
      "bn.js@<4.12.3": "4.12.3",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    },
    "ignoredBuiltDependencies": [
      "@fhenixprotocol/cofhe-contracts",
      "bufferutil",
      "esbuild",
      "keccak",
      "secp256k1",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ]
  }
}
