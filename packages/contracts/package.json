{
  "name": "@payrail/contracts",
  "private": true,
  "version": "0.1.0",
  "description": "Compliant, auditable, encrypted payroll rail for institutions",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fhenixprotocol/cofhe-contracts": "^0.1.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.8",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "ethers": "^6.15.0",
    "hardhat": "^2.26.0",
    "hardhat-deploy": "^0.11.45",
    "hardhat-gas-reporter": "^2.3.0",
    "mocha": "^11.7.1",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^2.1.0",
    "rimraf": "^6.0.1",
    "solhint": "^6.0.0",
    "solidity-coverage": "^0.8.16",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "clean": "rimraf ./fhevmTemp ./artifacts ./cache ./coverage ./types ./coverage.json ./dist",
    "compile": "hardhat --config hardhat.config.js compile",
    "typechain": "hardhat --config hardhat.config.js typechain",
    "test": "hardhat test",
    "test:arbitrumSepolia": "hardhat test --network arbitrumSepolia",
    "node": "hardhat --config hardhat.config.js node",
    "deploy:localhost": "hardhat --config hardhat.config.js deploy --network localhost",
    "deploy:arbitrumSepolia": "hardhat --config hardhat.config.js deploy --network arbitrumSepolia",
    "verify:arbitrumSepolia": "hardhat --config hardhat.config.js verify --network arbitrumSepolia",
    "export:sdk:localhost": "pnpm exec tsx scripts/export-to-sdk.ts --network localhost",
    "export:sdk:arbitrumSepolia": "pnpm exec tsx scripts/export-to-sdk.ts --network arbitrumSepolia",
    "deploy+export:arbitrumSepolia": "pnpm deploy:arbitrumSepolia && pnpm export:sdk:arbitrumSepolia"
  }
}
